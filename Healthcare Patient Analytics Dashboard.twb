      <aliases enabled='yes' />
      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.1ptfduf16y8f9e197knyq0aq93bk].[usr:Calculation_0130899114975233:qk]&quot;' value='Length of Stay' />
        </aliases>
      </column>
      <column datatype='string' name='[Admission Type]' role='dimension' type='nominal' />
      <column caption='Avg Billing' datatype='real' name='[Calculation_0130899113975808]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Billing Amount])' />
      </column>
      <column caption='Avg Length of Stay' datatype='real' name='[Calculation_0130899114975233]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(DATEDIFF(&apos;day&apos;, [Date of Admission], [Discharge Date]))' />
      </column>
      <column caption='Monthly Revenue' datatype='real' name='[Calculation_0130899115302914]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED DATETRUNC(&apos;month&apos;, [Date of Admission]) : SUM([Billing Amount]) }' />
      </column>
      <column caption='Total Patients' datatype='integer' name='[Calculation_0130899115757571]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Name])' />
      </column>
      <column caption='Total Revenue' datatype='real' name='[Calculation_0130899115978756]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Billing Amount])' />
      </column>
      <column caption='Age Group' datatype='string' name='[Calculation_0734531165614085]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Age] &lt; 20 THEN &quot;Below 20&quot;&#13;&#10;ELSEIF [Age] &lt;= 40 THEN &quot;20-40&quot;&#13;&#10;ELSEIF [Age] &lt;= 60 THEN &quot;41-60&quot;&#13;&#10;ELSE &quot;60+&quot;&#13;&#10;END' />
      </column>
